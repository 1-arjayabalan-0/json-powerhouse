{
    "name": "json-powerhouse-vscode",
    "author": {
        "name": "Jaya Balan A R",
        "email": "jsonpowerhousesupport@codarivu.com",
        "url": ""
    },
    "repository": {
        "url": "https://github.com/1-arjayabalan-0/json-powerhouse",
        "directory": "json-powerhouse",
        "type": "github"
    },
    "license": "MIT",
    "displayName": "JSON PowerHouse",
    "description": "All-in-one JSON tools for VS Code - Format, Minify, Validate, Diff, Tree View, and Generate Code",
    "version": "1.0.0",
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Formatters",
        "Programming Languages"
    ],
    "activationEvents": [
        "onLanguage:json",
        "onLanguage:jsonc"
    ],
    "main": "./dist/extension/src/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "json-powerhouse.format",
                "title": "JSON PowerHouse: Format JSON"
            },
            {
                "command": "json-powerhouse.minify",
                "title": "JSON PowerHouse: Minify JSON"
            },
            {
                "command": "json-powerhouse.normalize",
                "title": "JSON PowerHouse: Normalize JSON (Strip Comments)"
            },
            {
                "command": "json-powerhouse.toJson5",
                "title": "JSON PowerHouse: Convert to JSON5"
            },
            {
                "command": "json-powerhouse.flatten",
                "title": "JSON PowerHouse: Flatten JSON"
            },
            {
                "command": "json-powerhouse.unflatten",
                "title": "JSON PowerHouse: Unflatten JSON"
            },
            {
                "command": "json-powerhouse.validate",
                "title": "JSON PowerHouse: Validate JSON"
            },
            {
                "command": "json-powerhouse.treeView",
                "title": "JSON PowerHouse: Open Tree Viewer"
            },
            {
                "command": "json-powerhouse.diff",
                "title": "JSON PowerHouse: Compare JSON Files (Diff)"
            },
            {
                "command": "json-powerhouse.applyFix",
                "title": "JSON PowerHouse: Apply Auto-Fix"
            },
            {
                "command": "json-powerhouse.generateCSharp",
                "title": "JSON PowerHouse: Generate C# Classes"
            },
            {
                "command": "json-powerhouse.generateDart",
                "title": "JSON PowerHouse: Generate Dart Classes"
            },
            {
                "command": "json-powerhouse.generateGo",
                "title": "JSON PowerHouse: Generate Go Structs"
            },
            {
                "command": "json-powerhouse.generateJava",
                "title": "JSON PowerHouse: Generate Java Classes"
            },
            {
                "command": "json-powerhouse.generateKotlin",
                "title": "JSON PowerHouse: Generate Kotlin Classes"
            },
            {
                "command": "json-powerhouse.generatePhp",
                "title": "JSON PowerHouse: Generate PHP Classes"
            },
            {
                "command": "json-powerhouse.generatePython",
                "title": "JSON PowerHouse: Generate Python Classes"
            },
            {
                "command": "json-powerhouse.generateRust",
                "title": "JSON PowerHouse: Generate Rust Structs"
            },
            {
                "command": "json-powerhouse.generateSwift",
                "title": "JSON PowerHouse: Generate Swift Structs"
            },
            {
                "command": "json-powerhouse.generateTypeScript",
                "title": "JSON PowerHouse: Generate TypeScript Interfaces"
            }
        ],
        "submenus": [
            {
                "id": "jsonPowerhouse.menu",
                "label": "JSON PowerHouse"
            }
        ],
        "menus": {
            "editor/context": [
                {
                    "submenu": "jsonPowerhouse.menu",
                    "when": "editorLangId == json || editorLangId == jsonc",
                    "group": "navigation"
                }
            ],
            "jsonPowerhouse.menu": [
                {
                    "command": "json-powerhouse.format",
                    "group": "1_tools"
                },
                {
                    "command": "json-powerhouse.minify",
                    "group": "1_tools"
                },
                {
                    "command": "json-powerhouse.normalize",
                    "group": "1_tools"
                },
                {
                    "command": "json-powerhouse.toJson5",
                    "group": "1_tools"
                },
                {
                    "command": "json-powerhouse.flatten",
                    "group": "1_tools"
                },
                {
                    "command": "json-powerhouse.unflatten",
                    "group": "1_tools"
                },
                {
                    "command": "json-powerhouse.validate",
                    "group": "1_tools"
                },
                {
                    "command": "json-powerhouse.treeView",
                    "group": "2_views"
                },
                {
                    "command": "json-powerhouse.diff",
                    "group": "2_views"
                },
                {
                    "command": "json-powerhouse.generateCSharp",
                    "group": "3_generate"
                },
                {
                    "command": "json-powerhouse.generateDart",
                    "group": "3_generate"
                },
                {
                    "command": "json-powerhouse.generateGo",
                    "group": "3_generate"
                },
                {
                    "command": "json-powerhouse.generateJava",
                    "group": "3_generate"
                },
                {
                    "command": "json-powerhouse.generateKotlin",
                    "group": "3_generate"
                },
                {
                    "command": "json-powerhouse.generatePhp",
                    "group": "3_generate"
                },
                {
                    "command": "json-powerhouse.generatePython",
                    "group": "3_generate"
                },
                {
                    "command": "json-powerhouse.generateRust",
                    "group": "3_generate"
                },
                {
                    "command": "json-powerhouse.generateSwift",
                    "group": "3_generate"
                },
                {
                    "command": "json-powerhouse.generateTypeScript",
                    "group": "3_generate"
                }
            ]
        },
        "configuration": {
            "title": "JSON PowerHouse",
            "properties": {
                "json-powerhouse.formatting.indentation": {
                    "type": "string",
                    "default": "2",
                    "enum": [
                        "2",
                        "4",
                        "tab",
                        "0"
                    ],
                    "description": "Default indentation for formatting"
                },
                "json-powerhouse.formatting.keySorting": {
                    "type": "string",
                    "default": "none",
                    "enum": [
                        "none",
                        "asc",
                        "desc"
                    ],
                    "description": "Sort object keys"
                },
                "json-powerhouse.formatting.quoteStyle": {
                    "type": "string",
                    "default": "double",
                    "enum": [
                        "double",
                        "single"
                    ],
                    "description": "Quote style for keys"
                },
                "json-powerhouse.formatting.trailingCommas": {
                    "type": "boolean",
                    "default": false,
                    "description": "Add trailing commas"
                },
                "json-powerhouse.formatting.stripComments": {
                    "type": "boolean",
                    "default": true,
                    "description": "Strip comments from JSON"
                },
                "json-powerhouse.diff.allowComments": {
                    "type": "boolean",
                    "default": true,
                    "description": "Allow comments in JSON for diff comparison"
                },
                "json-powerhouse.diff.arrayStrategy": {
                    "type": "string",
                    "default": "index",
                    "enum": [
                        "index",
                        "key",
                        "ignore-order"
                    ],
                    "description": "Array comparison strategy for diff"
                },
                "json-powerhouse.diff.arrayMatchKey": {
                    "type": "string",
                    "default": "id",
                    "description": "Key to match array items when using key-based strategy"
                },
                "json-powerhouse.diff.showUnchanged": {
                    "type": "boolean",
                    "default": false,
                    "description": "Show unchanged nodes in diff view"
                },
                "json-powerhouse.validateOnSave": {
                    "type": "boolean",
                    "default": true,
                    "description": "Automatically validate JSON on save"
                },
                "json-powerhouse.validateOnChange": {
                    "type": "boolean",
                    "default": true,
                    "description": "Automatically validate JSON on change (debounced)"
                }
            }
        }
    },
    "scripts": {
        "compile": "npm run check-types && node esbuild.js",
        "check-types": "tsc --noEmit",
        "watch": "npm-run-all -p watch:*",
        "watch:esbuild": "node esbuild.js --watch",
        "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
        "vscode:prepublish": "npm run package",
        "package": "npm run check-types && node esbuild.js --production"

    },
    "devDependencies": {
        "@types/glob": "^8.1.0",
        "@types/mocha": "^10.0.1",
        "@types/node": "20.2.5",
        "@types/vscode": "^1.80.0",
        "@typescript-eslint/eslint-plugin": "^8.56.1",
        "@typescript-eslint/parser": "^8.56.1",
        "@vscode/test-electron": "^2.3.2",
        "esbuild": "^0.28.0",
        "eslint": "^10.0.2",
        "glob": "^8.1.0",
        "mocha": "^11.3.0",
        "typescript": "^5.1.3"
    },
    "dependencies": {
        "json5": "^2.2.3",
        "quicktype-core": "^23.2.6"
    }
}